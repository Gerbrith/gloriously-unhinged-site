---
import { getCollection } from 'astro:content';
import Head from '../components/Head.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
---

<html lang="en">
<head>
  <Head
    title="Blog — Gloriously Unhinged"
    description="Dispatches from the writing trenches"
  />
</head>

<body>
  <nav>
    <a href="/" class="nav-home">gloriously unhinged</a>
  </nav>

  <main>
    <header class="page-header">
      <h1>From the Blog</h1>
      <p class="page-subtitle">Dispatches from the writing trenches</p>
    </header>

    <section class="post-list">
      {posts.map((post) => (
        <a href={`/blog/${post.id}`} class="post-entry">
          <div class="post-text">
            <h3>{post.data.title}</h3>
            <p>{post.data.description}</p>
          </div>
          <span class="post-date">{post.data.date}</span>
        </a>
      ))}
    </section>

    <div class="back-link">
      <a href="/">← Back to home</a>
    </div>
  </main>
</body>
</html>

<style is:global>
  *, *::before, *::after {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  :root {
    --bg: #0d0d14;
    --surface: #151521;
    --surface-border: #2a2a3d;
    --text: #c8c8d4;
    --text-muted: #7a7a92;
    --accent: #8b7ec8;
    --accent-bright: #a594f9;
    --white: #e8e8f0;
  }

  html { font-size: 16px; scroll-behavior: smooth; }

  body {
    font-family: 'Inter', system-ui, sans-serif;
    background: var(--bg);
    color: var(--text);
    line-height: 1.6;
    min-height: 100vh;
    background-image: url('/purplesmoke.jpeg');
    background-size: cover;
    background-position: center top;
    background-repeat: no-repeat;
    background-attachment: fixed;
  }
    body::before {
    content: '';
    position: fixed;
    inset: 0;
    background: rgba(13, 13, 20, 0.85);
    z-index: -1;
  }

  nav {
    padding: 1.5rem;
    max-width: 800px;
    margin: 0 auto;
  }

  .nav-home {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 1.1rem;
    color: var(--text-muted);
    text-decoration: none;
    transition: color 0.2s;
  }

  .nav-home:hover { color: var(--accent-bright); }

  main {
    max-width: 720px;
    margin: 0 auto;
    padding: 2rem 1.5rem 5rem;
  }

  .page-header {
    margin-bottom: 3rem;
  }

  .page-header h1 {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 400;
    color: var(--white);
    margin-bottom: 0.5rem;
  }

  .page-subtitle {
    font-size: 0.9rem;
    color: var(--text-muted);
    font-style: italic;
  }

  .post-list {
    margin-bottom: 3rem;
  }

  .post-entry {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 1.25rem 0;
    border-bottom: 1px solid var(--surface-border);
    text-decoration: none;
    color: inherit;
    transition: opacity 0.2s;
  }

  .post-entry:hover { opacity: 0.8; }

  .post-text h3 {
    font-size: 1rem;
    font-weight: 600;
    color: var(--white);
    margin-bottom: 0.25rem;
  }

  .post-text p {
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  .post-date {
    font-size: 0.8rem;
    color: var(--accent);
    white-space: nowrap;
    margin-left: 2rem;
  }

  .back-link { text-align: center; }

  .back-link a {
    font-size: 0.85rem;
    color: var(--text-muted);
    text-decoration: none;
    transition: color 0.2s;
  }

  .back-link a:hover { color: var(--accent-bright); }

  @media (max-width: 640px) {
    .post-entry {
      flex-direction: column;
      gap: 0.25rem;
    }
    .post-date { margin-left: 0; }
  }
</style>