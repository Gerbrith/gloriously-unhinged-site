---
import Head from '../components/Head.astro';
---

<html lang="en">
<head>
    <Head
  title="Savanna Rioux — Gloriously Unhinged"
  description="Savanna Rioux. Writer. Transylvanian export. Mythology wiz, queen of darkness."
/>
</head>

<body>
  <nav>
    <a href="/" class="nav-home">gloriously unhinged</a>
  </nav>

  <main>
    <header class="bio-header">
      <span class="card-icon">♠</span>
      <h1>Savanna Rioux</h1>
      <p class="bio-subtitle">Mythology wiz, queen of dankness.</p>
    </header>

    <section class="bio-body">
      <p>
        Born in Transylvania and now living in the UK — proving she's not
        the only one to make that journey — Savanna Rioux writes dark fantasy
        driven by a love of complex characters and stories that don't let
        go easily.
      </p>

      <p>
        She speaks three languages, travels whenever she can, and has a habit
        of falling down historical rabbit holes for the sake of "research."
      </p>

      <p>
        When she's not writing or reading, she's usually painting walls,
        building furniture like it's a personal challenge, or adding to her
        growing collection of tattoos. She lives with her cat, who supervises
        everything and remains thoroughly unimpressed.
      </p>
    </section>

    <section class="bio-details">
      <div class="detail">
        <h3>Origin</h3>
        <p>Transylvania. Yes, that one.</p>
      </div>
      <div class="detail">
        <h3>Languages</h3>
        <p>Three, plus whatever the rabbit holes teach her</p>
      </div>
      <div class="detail">
        <h3>Side quests</h3>
        <p>Painting walls, building furniture, collecting tattoos</p>
      </div>
      <div class="detail">
        <h3>Supervisor</h3>
        <p>One cat. Thoroughly unimpressed.</p>
      </div>
    </section>
<section class="subscribe">
  <h2>Stay in Savanna's orbit</h2>
  <form class="subscribe-form" id="subscribe-form">
    <input type="email" name="fields[email]" placeholder="your@email.com" aria-label="Email address" required />
    <input type="hidden" name="ml-submit" value="1" />
    <input type="hidden" name="anticsrf" value="true" />
    <button type="submit">Subscribe</button>
  </form>
  <p class="subscribe-note" id="subscribe-note">No spam. Just darkness, on schedule.</p>
</section>
    <div class="back-link">
      <a href="/">← Back to home</a>
    </div>
  </main>
<script is:inline>
  document.getElementById('subscribe-form').addEventListener('submit', async (e) => {
    e.preventDefault();
    const form = e.target;
    const note = document.getElementById('subscribe-note');
    try {
      const res = await fetch('https://assets.mailerlite.com/jsonp/2260020/forms/186029700170123056/subscribe', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: new URLSearchParams(new FormData(form)),
      });
      const data = await res.json();
      if (data.success) {
        note.textContent = "You're in! Watch your inbox.";
        note.style.color = '#a594f9';
        form.reset();
      } else {
        note.textContent = 'Something went wrong. Try again?';
        note.style.color = '#ff6b6b';
      }
    } catch {
      note.textContent = 'Something went wrong. Try again?';
      note.style.color = '#ff6b6b';
    }
  });
</script>

</body>
</html>

<style is:global>
  *, *::before, *::after {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  :root {
    --bg: #0d0d14;
    --surface: #151521;
    --surface-border: #2a2a3d;
    --text: #c8c8d4;
    --text-muted: #7a7a92;
    --accent: #8b7ec8;
    --accent-bright: #a594f9;
    --white: #e8e8f0;
  }

  html { font-size: 16px; scroll-behavior: smooth; }

  body {
    font-family: 'Inter', system-ui, sans-serif;
    background: var(--bg);
    color: var(--text);
    line-height: 1.6;
    min-height: 100vh;
    background-image: url('/purplesmoke.jpeg');
    background-size: cover;
    background-position: center top;
    background-repeat: no-repeat;
    background-attachment: fixed;
  }
    body::before {
    content: '';
    position: fixed;
    inset: 0;
    background: rgba(13, 13, 20, 0.85);
    z-index: -1;
  }

  nav {
    padding: 1.5rem;
    max-width: 800px;
    margin: 0 auto;
  }

  .nav-home {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 1.1rem;
    color: var(--text-muted);
    text-decoration: none;
    transition: color 0.2s;
  }

  .nav-home:hover { color: var(--accent-bright); }

  main {
    max-width: 680px;
    margin: 0 auto;
    padding: 2rem 1.5rem 5rem;
  }

  .bio-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .card-icon {
    font-size: 1.5rem;
    color: var(--text-muted);
    display: block;
    margin-bottom: 0.75rem;
  }

  .bio-header h1 {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 400;
    color: var(--white);
    margin-bottom: 0.5rem;
  }

  .bio-subtitle {
    font-size: 0.9rem;
    color: var(--accent);
    font-style: italic;
  }

  .bio-body {
    margin-bottom: 3rem;
  }

  .bio-body p {
    font-size: 1rem;
    line-height: 1.8;
    margin-bottom: 1.25rem;
    color: var(--text);
  }

  .bio-body p:last-child {
    margin-bottom: 0;
  }

  .bio-details {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1px;
    background: var(--surface-border);
    border: 1px solid var(--surface-border);
    border-radius: 10px;
    overflow: hidden;
    margin-bottom: 3rem;
  }

  .detail {
    padding: 1.5rem;
    background: var(--surface);
  }

  .detail h3 {
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.4rem;
    font-weight: 600;
  }

  .detail p {
    font-size: 0.85rem;
    color: var(--text);
    line-height: 1.5;
  }

  .back-link { text-align: center; }

  .back-link a {
    font-size: 0.85rem;
    color: var(--text-muted);
    text-decoration: none;
    transition: color 0.2s;
  }

  .back-link a:hover { color: var(--accent-bright); }

  @media (max-width: 480px) {
    .bio-details {
      grid-template-columns: 1fr;
    }
  }
.subscribe {
  text-align: center;
  padding: 3rem 0;
  margin-bottom: 2rem;
}

.subscribe h2 {
  font-family: 'Inter', sans-serif;
  font-size: 1.1rem;
  font-weight: 500;
  color: var(--text);
  margin-bottom: 1.25rem;
}

.subscribe-form {
  display: flex;
  gap: 0.5rem;
  justify-content: center;
  margin-bottom: 0.75rem;
}

.subscribe-form input[type="email"] {
  flex: 1;
  max-width: 300px;
  padding: 0.7rem 1rem;
  border: 1px solid var(--surface-border);
  border-radius: 6px;
  background: var(--surface);
  color: var(--white);
  font-size: 0.9rem;
  font-family: inherit;
  outline: none;
  transition: border-color 0.2s;
}

.subscribe-form input[type="email"]::placeholder {
  color: var(--text-muted);
}

.subscribe-form input[type="email"]:focus {
  border-color: var(--accent);
}

.subscribe-form button {
  padding: 0.7rem 1.5rem;
  border: none;
  border-radius: 6px;
  background: var(--accent);
  color: var(--white);
  font-size: 0.9rem;
  font-weight: 600;
  font-family: inherit;
  cursor: pointer;
  transition: background 0.2s;
}

.subscribe-form button:hover {
  background: var(--accent-bright);
}

.subscribe-note {
  font-size: 0.75rem;
  color: var(--accent);
  font-style: italic;
}
</style>