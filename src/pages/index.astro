---
import Head from '../components/Head.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 3);
---

<html lang="en">
<head>
  <Head
    title="Gloriously Unhinged — Dark Romance · Dark Comedy · Darker Impulses"
    description="Two writers. One shared delusion that we could do better. Stories where the premise makes you say 'wait, what?' and the execution makes you say 'oh no, I'm invested.'"
  />
</head>

<body>
  <!-- ===== HERO ===== -->
  <section class="hero">
    <p class="tagline">Dark Romance · Dark Comedy · Darker Impulses</p>
    <h1>gloriously unhinged</h1>
    <p class="subtitle">
      Two writers. One shared delusion that we could do better. Stories
      where the premise makes you say <em>"wait, what?"</em> and the
      execution makes you say <em>"oh no, I'm invested."</em>
    </p>
  </section>

  <!-- ===== CARDS ===== -->
  <section class="cards">
    <a href="/nina" class="card">
      <span class="card-icon">♣</span>
      <h3>Nina Dahl</h3>
      <p>Axe-wielding fantasy enthusiast</p>
    </a>
	<a href="/books" class="card">
      <span class="card-icon">♦</span>
      <h3>our books</h3>
      <p>The unhinged things we wrote together</p>
    </a>    
    <a href="/savanna" class="card">
      <span class="card-icon">♠</span>
      <h3>Savanna Rioux</h3>
      <p>Mythology wiz, queen of dankness</p>
    </a>
  </section>

  <!-- ===== FEATURED ===== -->
  <section class="featured">
    <h2 class="section-label">Featured</h2>
    <a href="/books" class="featured-card"></>
      <div class="featured-cover">
        <!-- UPDATE THIS: replace with your actual cover image filename -->
        <img src="/bbcovermockuppulp.png" alt="Blurred Borders cover" />
      </div>
      <div class="featured-info">
        <h3>Blurred Borders</h3>
        <p class="featured-genre">M/M Dark Romance · Romantic Suspense</p>
        <p class="featured-blurb">
          A federal agent goes undercover as a domestic worker. In a maid
          uniform. Inside the household of the man he's investigating.
          What could possibly go wrong? <span class="emphasis">Everything.</span>
        </p>
      </div>
    </a>
  </section>

  <!-- ===== BLOG ===== -->
  <section class="blog">
    <h2 class="section-label">From the Blog</h2>

     {posts.map((post) => (
      <a href={`/blog/${post.id}`} class="blog-entry">
        <div class="blog-text">
          <h3>{post.data.title}</h3>
          <p>{post.data.description}</p>
        </div>
        <span class="blog-date">{post.data.date}</span>
      </a>
    ))}

    <div class="blog-more">
      <a href="/blog">More blog posts →</a>
    </div>
  </section>

  <!-- ===== SUBSCRIBE ===== -->
  <section class="subscribe">
    <h2>Get notified when we unleash something new</h2>
    <form class="subscribe-form" action="https://assets.mailerlite.com/jsonp/2261979/forms/184496156830598810/subscribe" method="post" target="_blank">
  <input type="email" name="fields[email]" placeholder="your@email.com" aria-label="Email address" required />
  <input type="hidden" name="ml-submit" value="1" />
  <input type="hidden" name="anticsrf" value="true" />
  <button type="submit">Subscribe</button>
</form>

<style is:global>
  /* ===== RESET & BASE ===== */
  *, *::before, *::after {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  :root {
    --bg: #0d0d14;
    --surface: #151521;
    --surface-border: #2a2a3d;
    --text: #c8c8d4;
    --text-muted: #7a7a92;
    --accent: #8b7ec8;
    --accent-bright: #a594f9;
    --white: #e8e8f0;
  }

  html {
    font-size: 16px;
    scroll-behavior: smooth;
  }

  body {
    font-family: 'Inter', system-ui, sans-serif;
    background: var(--bg);
    color: var(--text);
    line-height: 1.6;
    min-height: 100vh;
    background-image: url('/purplesmoke.jpeg');
    background-size: cover;
    background-position: center top;
    background-repeat: no-repeat;
    background-attachment: fixed;
  }
    body::before {
    content: '';
    position: fixed;
    inset: 0;
    background: rgba(13, 13, 20, 0.85);
    z-index: -1;
  }

  /* ===== HERO ===== */
  .hero {
    text-align: center;
    padding: 6rem 1.5rem 4rem;
    max-width: 720px;
    margin: 0 auto;
  }

  .tagline {
    font-size: 0.75rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 1rem;
  }

  .hero h1 {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 400;
    color: var(--white);
    margin-bottom: 1.5rem;
    letter-spacing: -0.01em;
  }

  .subtitle {
    font-size: 1.05rem;
    color: var(--text-muted);
    max-width: 560px;
    margin: 0 auto;
    line-height: 1.7;
  }

  .subtitle em {
    font-family: 'Playfair Display', Georgia, serif;
    color: var(--accent-bright);
    font-style: italic;
  }

  /* ===== CARDS ===== */
  .cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    max-width: 800px;
    margin: 0 auto 4rem;
    border: 1px solid var(--surface-border);
    border-radius: 8px;
    overflow: hidden;
  }

  .card {
    text-align: center;
    padding: 2rem 1.5rem;
    border-right: 1px solid var(--surface-border);
    transition: background 0.2s;
    cursor: pointer;
  }

  .card:last-child {
    border-right: none;
  }

  .card:hover {
    background: var(--surface);
  }

  .card-icon {
    font-size: 1.25rem;
    color: var(--text-muted);
    display: block;
    margin-bottom: 0.75rem;
  }

  .card h3 {
    font-family: 'Inter', sans-serif;
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--white);
    margin-bottom: 0.4rem;
  }

  .card p {
    font-size: 0.8rem;
    color: var(--text-muted);
    line-height: 1.5;
  }

  /* ===== FEATURED ===== */
  .featured {
    max-width: 800px;
    margin: 0 auto 4rem;
    padding: 0 1.5rem;
  }

  .section-label {
    font-size: 0.7rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 1.25rem;
    font-weight: 600;
  }

  .featured-card {
    display: flex;
    gap: 1.75rem;
    padding: 1.75rem;
    border: 1px solid var(--surface-border);
    border-radius: 10px;
    background: var(--surface);
    align-items: flex-start;
  }

  .featured-cover {
    flex-shrink: 0;
    width: 110px;
  }

  .featured-cover img {
    width: 100%;
    height: auto;
    border-radius: 4px;
    display: block;
  }

  .featured-info h3 {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--white);
    margin-bottom: 0.3rem;
  }

  .featured-genre {
    font-size: 0.8rem;
    color: var(--accent);
    margin-bottom: 0.75rem;
  }

  .featured-blurb {
    font-size: 0.9rem;
    color: var(--text);
    line-height: 1.65;
  }

  .featured-blurb .emphasis {
    text-decoration: underline;
    text-decoration-color: var(--accent);
    text-underline-offset: 3px;
    color: var(--white);
  }

  /* ===== BLOG ===== */
  .blog {
    max-width: 800px;
    margin: 0 auto 4rem;
    padding: 0 1.5rem;
  }

  .blog-entry {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 1.25rem 0;
    border-bottom: 1px solid var(--surface-border);
    text-decoration: none;
    color: inherit;
    transition: opacity 0.2s;
  }

  .blog-entry:hover {
    opacity: 0.8;
  }

  .blog-text h3 {
    font-size: 1rem;
    font-weight: 600;
    color: var(--white);
    margin-bottom: 0.25rem;
  }

  .blog-text p {
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  .blog-date {
    font-size: 0.8rem;
    color: var(--accent);
    white-space: nowrap;
    margin-left: 2rem;
  }

  /* ===== SUBSCRIBE ===== */
  .subscribe {
    text-align: center;
    padding: 4rem 1.5rem 5rem;
    max-width: 500px;
    margin: 0 auto;
  }

  .subscribe h2 {
    font-family: 'Inter', sans-serif;
    font-size: 1.1rem;
    font-weight: 500;
    color: var(--text);
    margin-bottom: 1.5rem;
  }

  .subscribe-form {
    display: flex;
    gap: 0.5rem;
    justify-content: center;
    margin-bottom: 0.75rem;
  }

  .subscribe-form input {
    flex: 1;
    max-width: 300px;
    padding: 0.7rem 1rem;
    border: 1px solid var(--surface-border);
    border-radius: 6px;
    background: var(--surface);
    color: var(--white);
    font-size: 0.9rem;
    font-family: inherit;
    outline: none;
    transition: border-color 0.2s;
  }

  .subscribe-form input::placeholder {
    color: var(--text-muted);
  }

  .subscribe-form input:focus {
    border-color: var(--accent);
  }

  .subscribe-form button {
    padding: 0.7rem 1.5rem;
    border: none;
    border-radius: 6px;
    background: var(--accent);
    color: var(--white);
    font-size: 0.9rem;
    font-weight: 600;
    font-family: inherit;
    cursor: pointer;
    transition: background 0.2s;
  }

  .subscribe-form button:hover {
    background: var(--accent-bright);
  }

  .subscribe-note {
    font-size: 0.75rem;
    color: var(--accent);
    font-style: italic;
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 640px) {
    .cards {
      grid-template-columns: 1fr;
    }

    .card {
      border-right: none;
      border-bottom: 1px solid var(--surface-border);
    }

    .card:last-child {
      border-bottom: none;
    }

    .featured-card {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }

    .featured-cover {
      width: 140px;
    }

    .blog-entry {
      flex-direction: column;
      gap: 0.25rem;
    }

    .blog-date {
      margin-left: 0;
    }

    .subscribe-form {
      flex-direction: column;
      align-items: center;
    }

    .subscribe-form input {
      max-width: 100%;
      width: 100%;
    }
  }
    .blog-more {
    text-align: center;
    margin-top: 1.5rem;
  }

  .blog-more a {
    font-size: 0.85rem;
    color: var(--text-muted);
    text-decoration: none;
    transition: color 0.2s;
  }

  .blog-more a:hover {
    color: var(--accent-bright);
  }
    .featured-card {
    text-decoration: none;
    color: inherit;
  }
</style>