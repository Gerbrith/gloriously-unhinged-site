---
import { getCollection, render } from 'astro:content';
import Head from '../../components/Head.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<html lang="en">
<head>
  <Head
    title={`${post.data.title} — Gloriously Unhinged`}
    description={post.data.description}
  />
</head>

<body>
  <nav>
    <a href="/" class="nav-home">gloriously unhinged</a>
  </nav>

  <main>
    <article>
      <header class="post-header">
        <span class="post-date">{post.data.date}</span>
        <h1>{post.data.title}</h1>
        <p class="post-description">{post.data.description}</p>
      </header>

      <div class="post-content">
        <Content />
      </div>
    </article>

    <div class="back-link">
      <a href="/blog">← All posts</a>
    </div>
  </main>
</body>
</html>

<style is:global>
  *, *::before, *::after {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  :root {
    --bg: #0d0d14;
    --surface: #151521;
    --surface-border: #2a2a3d;
    --text: #c8c8d4;
    --text-muted: #7a7a92;
    --accent: #8b7ec8;
    --accent-bright: #a594f9;
    --white: #e8e8f0;
  }

  html { font-size: 16px; scroll-behavior: smooth; }

  body {
    font-family: 'Inter', system-ui, sans-serif;
    background: var(--bg);
    color: var(--text);
    line-height: 1.6;
    min-height: 100vh;
    background-image: url('/purplesmoke.jpeg');
    background-size: cover;
    background-position: center top;
    background-repeat: no-repeat;
    background-attachment: fixed;
  }
    body::before {
    content: '';
    position: fixed;
    inset: 0;
    background: rgba(13, 13, 20, 0.85);
    z-index: -1;
  }

  nav {
    padding: 1.5rem;
    max-width: 800px;
    margin: 0 auto;
  }

  .nav-home {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 1.1rem;
    color: var(--text-muted);
    text-decoration: none;
    transition: color 0.2s;
  }

  .nav-home:hover { color: var(--accent-bright); }

  main {
    max-width: 680px;
    margin: 0 auto;
    padding: 2rem 1.5rem 5rem;
  }

  .post-header {
    margin-bottom: 3rem;
    border-bottom: 1px solid var(--surface-border);
    padding-bottom: 2rem;
  }

  .post-header .post-date {
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--accent);
    display: block;
    margin-bottom: 0.75rem;
  }

  .post-header h1 {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 700;
    color: var(--white);
    margin-bottom: 0.75rem;
    line-height: 1.3;
  }

  .post-description {
    font-size: 1rem;
    color: var(--text-muted);
    font-style: italic;
  }

  .post-content {
    margin-bottom: 3rem;
  }

  .post-content p {
    font-size: 1rem;
    line-height: 1.85;
    margin-bottom: 1.5rem;
    color: var(--text);
  }

  .post-content h2 {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 1.4rem;
    color: var(--white);
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }

  .post-content h3 {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--white);
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }

  .post-content em {
    color: var(--accent-bright);
  }

  .post-content strong {
    color: var(--white);
    font-weight: 600;
  }

  .post-content blockquote {
    border-left: 3px solid var(--accent);
    padding-left: 1.25rem;
    margin: 1.5rem 0;
    color: var(--text-muted);
    font-style: italic;
  }

  .post-content ul, .post-content ol {
    margin: 1rem 0 1.5rem 1.5rem;
    color: var(--text);
  }

  .post-content li {
    margin-bottom: 0.5rem;
    line-height: 1.7;
  }

  .post-content a {
    color: var(--accent-bright);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .post-content a:hover {
    color: var(--white);
  }

  .post-content hr {
    border: none;
    border-top: 1px solid var(--surface-border);
    margin: 2.5rem 0;
  }

  .back-link { text-align: center; }

  .back-link a {
    font-size: 0.85rem;
    color: var(--text-muted);
    text-decoration: none;
    transition: color 0.2s;
  }

  .back-link a:hover { color: var(--accent-bright); }
</style>